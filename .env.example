# =====================================================================
# Ok, Box Box Environment Configuration (Week 12)
# Copy to .env and fill in values for your environment.
# =====================================================================

# ---------------------------------------------------------------------
# CORE
# ---------------------------------------------------------------------
# Environment: local | staging | production
APP_ENV=local
NODE_ENV=development
PORT=3001
HOST=localhost
BASE_URL=http://localhost:3001

# ---------------------------------------------------------------------
# DATABASE (Required)
# ---------------------------------------------------------------------
# PostgreSQL connection string (TimescaleDB compatible)
DATABASE_URL=postgresql://controlbox:controlbox_dev@localhost:5432/controlbox
DB_POOL_SIZE=10

# ---------------------------------------------------------------------
# REDIS (Optional)
# ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ---------------------------------------------------------------------
# AUTHENTICATION (Required)
# ---------------------------------------------------------------------
# MUST be at least 32 characters. CHANGE IN PRODUCTION!
JWT_SECRET=controlbox_dev_secret_change_in_production
JWT_EXPIRES_IN=24h

# Salt for API key hashing. MUST be at least 16 characters.
API_KEY_SALT=dev-salt-change-me

# Enable DEV auth mode (MUST be false in staging/production)
DEV_AUTH_MODE=true

# ---------------------------------------------------------------------
# PUBLIC ACCESS
# ---------------------------------------------------------------------
PUBLIC_SPECTATOR_MODE=true
PUBLIC_MAX_CONCURRENT_SESSIONS=10

# ---------------------------------------------------------------------
# TELEMETRY INGESTION
# ---------------------------------------------------------------------
TELEMETRY_INGEST_ENABLED=true
TELEMETRY_MAX_RATE_HZ=60

# ---------------------------------------------------------------------
# DATA RETENTION (days)
# ---------------------------------------------------------------------
RETENTION_RAW_FRAMES_DAYS=14
RETENTION_TIMING_DAYS=90
RETENTION_HIGHLIGHTS_DAYS=365
RETENTION_AUDIT_DAYS=365

# ---------------------------------------------------------------------
# COST GUARDRAILS
# ---------------------------------------------------------------------
MAX_REPLAY_STORAGE_GB=10
MAX_OVERLAY_CLIENTS_PER_SESSION=50
MAX_SESSIONS_PER_ORG=100

# ---------------------------------------------------------------------
# OBSERVABILITY
# ---------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty
METRICS_ENABLED=true

# ---------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------
# iRacing Relay
# ---------------------------------------------------------------------
IRACING_RELAY_HOST=localhost
IRACING_RELAY_PORT=3002

# ---------------------------------------------------------------------
# AI Layer (placeholder)
# ---------------------------------------------------------------------
AI_INFERENCE_URL=http://localhost:8000
AI_MODEL_ID=default

# ---------------------------------------------------------------------
# BUILD INFO (injected at build/deploy time)
# ---------------------------------------------------------------------
BUILD_VERSION=dev
BUILD_SHA=local
BUILD_TIME=2025-12-30T00:00:00Z


# =====================================================================
# STAGING OVERRIDES
# =====================================================================
# APP_ENV=staging
# NODE_ENV=production
# DEV_AUTH_MODE=false
# JWT_SECRET=<generate-strong-secret>
# API_KEY_SALT=<generate-strong-salt>
# DATABASE_URL=<staging-db-url>
# REDIS_ENABLED=true
# LOG_FORMAT=json

# =====================================================================
# PRODUCTION OVERRIDES
# =====================================================================
# APP_ENV=production
# NODE_ENV=production
# DEV_AUTH_MODE=false  # REQUIRED
# JWT_SECRET=<generate-strong-secret>  # REQUIRED: 32+ chars
# API_KEY_SALT=<generate-strong-salt>  # REQUIRED: 16+ chars
# REDIS_ENABLED=true
# LOG_LEVEL=info
# LOG_FORMAT=json
