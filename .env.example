# SOG Kneeboard Server Configuration
# Copy this file to .env and configure for your system

# Security token for API authentication
TOKEN=sog-kneeboard-secure-token-2024

# Server port (default: 31337)
PORT=31337

# Path to Arma 3 marker inbox file
# Windows: C:\Users\YourUsername\Documents\Arma 3\sog_ipad_inbox.json
# Mac: /Users/YourUsername/Documents/Arma 3/sog_ipad_inbox.json
INBOX_PATH=%USERPROFILE%/Documents/Arma 3/sog_ipad_inbox.json
